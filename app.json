{
  "expo": {
    "name": "TourOfHonor",
    "slug": "TourOfHonor",
    "version": "4.1.0",
    "orientation": "portrait",
    "icon": "./app/assets/appIcon.png",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allows you to submit your memorial visits using the photos in your camera roll."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8f4f4",
          "image": "./app/assets/splash.png"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "compileSdkVersion": 36,
            "minSdkVersion": 30,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "bundleIdentifier": "com.ambitiousNerds.TourOfHonor",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.ambitiousNerds.TourOfHonor",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "58f65fc8-31fd-4e42-9b47-506ffc6c05bf"
      },
      "tohApiKey": ""
    },
    "scheme": "toh"
  }
}
